    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "obfuscate": "node obfuscate.js"
  },
  "keywords": [],
  "author": "璇洛",
  "license": "ISC",
  "description": "StarRocom 星洛 - 洛克王国工具",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^4.1.1"
  },
  "dependencies": {
    "debug": "^4.4.3",
    "env-paths": "^2.2.1",
    "progress": "^2.0.3",
    "fs-extra": "^8.1.0",
    "extract-zip": "^2.0.1",
    "got": "^11.8.6",
    "semver": "^6.3.1",
    "undici-types": "^6.21.0",
    "sumchecker": "^3.0.1",
    "ms": "^2.1.3",
    "yauzl": "^2.10.0",
    "graceful-fs": "^4.2.11",
    "get-stream": "^5.2.0",
    "universalify": "^0.1.2",
    "pump": "^3.0.4",
    "jsonfile": "^4.0.0",
    "boolean": "^3.2.0",
    "matcher": "^3.0.0",
    "es6-error": "^4.1.1",
    "serialize-error": "^7.0.1",
    "http2-wrapper": "^1.0.3",
    "roarr": "^2.15.4",
    "cacheable-lookup": "^5.0.4",
    "lowercase-keys": "^2.0.0",
    "cacheable-request": "^7.0.4",
    "p-cancelable": "^2.1.1",
    "responselike": "^2.0.1",
    "defer-to-connect": "^2.0.1",
    "http-cache-semantics": "^4.2.0",
    "keyv": "^4.5.4",
    "clone-response": "^1.0.3",
    "mimic-response": "^1.0.1",
    "quick-lru": "^5.1.1",
